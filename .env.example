# Получить на https://my.telegram.org → API development tools
API_ID=
API_HASH=

# Получить локально через: python scripts/generate_session.py
# ВНИМАНИЕ: SESSION_STRING = полный доступ к Telegram-аккаунту. Не коммитить.
SESSION_STRING=

# Список целевых групп через запятую.
# Можно @username или числовой id (-100... для супергрупп/каналов).
TARGET_GROUPS=@your_group_1,@your_group_2,-1001234567890

# --- Источник постов: приватный канал, в котором ты пишешь черновики ---

# @username или числовой id (-100...) канала-источника.
# Канал должен быть доступен аккаунту userbot'а (он подписан / создатель).
DRAFTS_SOURCE=@my_drafts_channel

# Сколько последних сообщений канала сканировать. 500 хватает с запасом.
DRAFTS_SCAN_LIMIT=500

# Хэштег-маркер активных постов. Сообщения без него игнорируются.
ACTIVE_TAG=#active

# --- Расписание ---

# Времена постинга через запятую в формате HH:MM
SCHEDULE=10:00,19:30

# IANA timezone
TIMEZONE=Asia/Tashkent

# --- Опциональные ---

# Случайная пауза между группами (секунды)
DELAY_BETWEEN_GROUPS_MIN=8
DELAY_BETWEEN_GROUPS_MAX=25

# Случайный сдвиг старта от расписания (минуты), чтобы не палиться роботом
JITTER_MINUTES=7

# Максимум секунд, которые мы готовы ждать на SlowMode
MAX_SLOW_MODE_WAIT=120

# Перемешивать порядок групп при рассылке
SHUFFLE_GROUPS=true

# DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

[Unit]
Description=Telegram userbot — автопостинг в свои группы
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=300
StartLimitBurst=10

[Service]
Type=simple
# Поправь User и пути под то, куда реально склонировал репозиторий.
User=ubuntu
WorkingDirectory=/home/ubuntu/Bot_Monitoring
ExecStart=/home/ubuntu/Bot_Monitoring/.venv/bin/python -m src.main
Restart=on-failure
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
